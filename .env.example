# CloudScout environment variables — copy to .env and fill in.
# .env is gitignored; never commit real credentials.

# Postgres connection string. Get this from Supabase:
#   Project Settings → Database → Connection string → Connection pooling (port 6543).
# If unset, database.py falls back to sqlite:///cloudscout.db (local dev).
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Optional. Enables the AI Scout chat in api.py and app.py.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Override the FastAPI base URL in the iOS app at build time
# (otherwise the value in APIClient.swift is used).
# API_BASE=https://cloudscout-api.fly.dev
